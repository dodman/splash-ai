// Splash AI — Prisma schema
// Requires PostgreSQL with the `vector` extension.
// Run: npx prisma migrate dev --name init

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [vector]
}

// ============================================================================
// Enums
// ============================================================================

enum StudentLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

enum ResponseLength {
  CONCISE
  NORMAL
  DETAILED
}

enum TutorMode {
  LEARN
  PRACTICE
  REVISION
  DIRECT
}

enum MessageRole {
  USER
  ASSISTANT
  SYSTEM
}

enum MaterialStatus {
  PENDING
  PROCESSING
  READY
  FAILED
}

enum QuestionType {
  MCQ
  SHORT
  SCENARIO
}

// ============================================================================
// Auth (NextAuth v5 + credentials)
// ============================================================================

model User {
  id             String    @id @default(cuid())
  email          String    @unique
  name           String?
  hashedPassword String?
  image          String?
  emailVerified  DateTime?
  isAdmin        Boolean   @default(false)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  accounts       Account[]
  sessions       Session[]
  settings       UserSettings?

  ownedCourses   Course[]
  enrollments    Enrollment[]
  chatSessions   ChatSession[]
  quizzes        Quiz[]
  quizAttempts   QuizAttempt[]
  progress       TopicProgress[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ============================================================================
// Settings
// ============================================================================

model UserSettings {
  id              String         @id @default(cuid())
  userId          String         @unique
  level           StudentLevel   @default(INTERMEDIATE)
  preferredLength ResponseLength @default(NORMAL)
  darkMode        Boolean        @default(false)
  aiProvider      String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ============================================================================
// Courses
// ============================================================================

model Course {
  id        String   @id @default(cuid())
  title     String
  code      String
  degree    String
  year      Int
  semester  Int
  lecturer  String?
  ownerId   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  owner         User            @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  enrollments   Enrollment[]
  materials     CourseMaterial[]
  chatSessions  ChatSession[]
  quizzes       Quiz[]
  topicProgress TopicProgress[]

  @@index([ownerId])
}

model Enrollment {
  id         String   @id @default(cuid())
  userId     String
  courseId   String
  enrolledAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
  @@index([userId])
  @@index([courseId])
}

// ============================================================================
// Materials + chunks (RAG)
// ============================================================================

model CourseMaterial {
  id          String         @id @default(cuid())
  courseId    String
  filename    String
  mimeType    String
  size        Int
  storageKey  String
  status      MaterialStatus @default(PENDING)
  error       String?
  pages       Int?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  course Course          @relation(fields: [courseId], references: [id], onDelete: Cascade)
  chunks MaterialChunk[]

  @@index([courseId])
  @@index([status])
}

model MaterialChunk {
  id          String  @id @default(cuid())
  materialId  String
  chunkIndex  Int
  content     String  @db.Text
  tokenCount  Int
  page        Int?
  metadata    Json?
  // Added via raw SQL in migration: embedding vector(1536)
  embedding   Unsupported("vector(1536)")?

  material CourseMaterial @relation(fields: [materialId], references: [id], onDelete: Cascade)

  @@unique([materialId, chunkIndex])
  @@index([materialId])
}

// ============================================================================
// Chat
// ============================================================================

model ChatSession {
  id        String    @id @default(cuid())
  userId    String
  courseId  String?
  mode      TutorMode @default(LEARN)
  title     String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  user     User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  course   Course?        @relation(fields: [courseId], references: [id], onDelete: SetNull)
  messages ChatMessage[]

  @@index([userId])
  @@index([courseId])
}

model ChatMessage {
  id         String      @id @default(cuid())
  sessionId  String
  role       MessageRole
  content    String      @db.Text
  citations  Json?
  tokensUsed Int?
  createdAt  DateTime    @default(now())

  session ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
}

// ============================================================================
// Quiz
// ============================================================================

model Quiz {
  id        String   @id @default(cuid())
  userId    String
  courseId  String?
  title     String
  topic     String?
  createdAt DateTime @default(now())

  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  course    Course?       @relation(fields: [courseId], references: [id], onDelete: SetNull)
  questions QuizQuestion[]
  attempts  QuizAttempt[]

  @@index([userId])
  @@index([courseId])
}

model QuizQuestion {
  id            String       @id @default(cuid())
  quizId        String
  order         Int
  type          QuestionType
  prompt        String       @db.Text
  options       Json?
  correctAnswer String       @db.Text
  explanation   String       @db.Text
  topic         String?

  quiz Quiz @relation(fields: [quizId], references: [id], onDelete: Cascade)

  @@index([quizId])
}

model QuizAttempt {
  id          String    @id @default(cuid())
  userId      String
  quizId      String
  score       Float
  maxScore    Int
  responses   Json
  startedAt   DateTime  @default(now())
  completedAt DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  quiz Quiz @relation(fields: [quizId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([quizId])
}

// ============================================================================
// Progress
// ============================================================================

model TopicProgress {
  id             String   @id @default(cuid())
  userId         String
  courseId       String?
  topic          String
  mastery        Float    @default(0)
  sessionCount   Int      @default(0)
  lastStudiedAt  DateTime @default(now())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  course Course? @relation(fields: [courseId], references: [id], onDelete: SetNull)

  @@unique([userId, courseId, topic])
  @@index([userId])
  @@index([courseId])
}
