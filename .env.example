# --- Database ---
# Requires PostgreSQL 16+ with the `vector` extension enabled (Neon, Supabase,
# or local via `CREATE EXTENSION vector;`).
DATABASE_URL="postgresql://user:pass@localhost:5432/splash?schema=public"

# --- Auth (NextAuth v5) ---
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=""
NEXTAUTH_URL="http://localhost:3000"
AUTH_TRUST_HOST="true"

# --- AI Provider ---
# Supported: openai  (add more adapters in src/providers/ai/)
AI_PROVIDER="openai"
OPENAI_API_KEY=""
CHAT_MODEL="gpt-4o-mini"
EMBEDDING_MODEL="text-embedding-3-small"
EMBEDDING_DIM="1536"

# --- Storage ---
# Supported: local  (S3 / Supabase coming next — see src/providers/storage/)
STORAGE_PROVIDER="local"
UPLOAD_PATH="./uploads"
MAX_UPLOAD_MB="25"

# --- Academy Integration ---
# Secret key shared between Splash Academy and Splash AI.
# Generate with: openssl rand -hex 32
# Set the same value as SPLASH_AI_API_KEY in Splash Academy's .env
ACADEMY_API_KEY="change-me-to-a-random-secret"
